NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this with NEXT_PUBLIC_ and never commit a real key.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Payment Links for the two support products (browser-safe URLs).
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_5W=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_15W=

# Server-only Stripe integration (webhook + automatic payment recording).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI assistants (server-only).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Team notifications via Telegram (server-only): bot token from @BotFather
# and the chat id the team reads. Without these, notifications are logged
# with status "skipped" and nothing is sent.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Absolute site origin used in notification links and auth redirects.
NEXT_PUBLIC_SITE_URL=https://pythonmethodcenter.com
